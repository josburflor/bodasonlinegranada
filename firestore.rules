rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verify email if needed
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) 
        && data.keys().size() <= 7
        && data.uid is string && data.uid == request.auth.uid
        && data.role in ['couple', 'vendor']
        && data.email is string && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    function isValidProvider(data) {
      return data.keys().hasAll(['name', 'category', 'location', 'userId'])
        && data.keys().size() <= 15
        && data.userId is string && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 128
        && data.category is string && data.category.size() <= 64
        && data.location is string && data.location.size() <= 256
        && (!('rating' in data) || (data.rating is number))
        && (!('reviews' in data) || (data.reviews is number))
        && (!('imageUrl' in data) || (data.imageUrl is string))
        && (!('isPremium' in data) || (data.isPremium is bool))
        && (!('description' in data) || (data.description is string && data.description.size() <= 5000))
        && (!('phone' in data) || (data.phone is string))
        && (!('gallery' in data) || (data.gallery is list))
        && (!('testimonials' in data) || (data.testimonials is list))
        && (!('packages' in data) || (data.packages is list));
    }

    function isValidSpace(data) {
      return data.keys().hasAll(['name', 'description'])
        && data.keys().size() <= 8
        && data.name is string && data.name.size() <= 128
        && data.description is string && data.description.size() <= 5000
        && (!('rating' in data) || (data.rating is number))
        && (!('imageUrl' in data) || (data.imageUrl is string))
        && (!('location' in data) || (data.location is string));
    }

    function isValidWedding(data) {
      return data.keys().hasAll(['ownerId', 'status'])
        && data.keys().size() <= 12
        && data.ownerId is string && data.ownerId == request.auth.uid
        && data.status in ['planning', 'finalized', 'completed']
        && (!('date' in data) || (data.date is string))
        && (!('location' in data) || (data.location is string && data.location.size() <= 256))
        && (!('budget' in data) || (data.budget is number))
        && (!('spent' in data) || (data.spent is number))
        && (!('religion' in data) || (data.religion is string))
        && (!('weddingColor' in data) || (data.weddingColor is string))
        && (!('updatedAt' in data) || (data.updatedAt == request.time));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'content'])
        && data.senderId is string && data.senderId == request.auth.uid
        && data.receiverId is string
        && data.content is string && data.content.size() <= 2000;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'role']);
      allow delete: if false;
    }

    match /providers/{providerId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProvider(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidProvider(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /spaces/{spaceId} {
      allow read: if true;
      allow write: if false; 
    }

    match /weddings/{weddingId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidWedding(incoming());
      allow update: if isOwner(existing().ownerId) && isValidWedding(incoming())
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['date', 'location', 'status', 'updatedAt', 'budget', 'spent', 'religion', 'weddingColor']))
          && incoming().ownerId == existing().ownerId
        );
      allow delete: if isOwner(existing().ownerId);
    }

    match /messages/{messageId} {
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow update: if isSignedIn() && resource.data.receiverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
